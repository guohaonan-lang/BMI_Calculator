<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_rounded_bg"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="16dp">

    <!-- 顶部标题 DATE -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="@string/date_picker_date"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:fontFamily="@font/font_extrabold"/>

    <!-- 三列滚轮容器：月份 Wheel + 日期 Wheel + 年份 Wheel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- 第一列：月份 Apr/May/June... -->
        <com.contrarywind.view.WheelView
            android:id="@+id/wheel_month"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- 第二列：数字日期 19/20/21... -->
        <com.contrarywind.view.WheelView
            android:id="@+id/wheel_day"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- 第三列：年份 2016/2017/2018... -->
        <com.contrarywind.view.WheelView
            android:id="@+id/wheel_year"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />
    </LinearLayout>


    <!-- 底部双按钮 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="120dp"
            android:layout_height="56dp"
            android:backgroundTint="#EEEEEE"
            android:text="@string/data_cancel"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:fontFamily="@font/font_extrabold"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="10dp"/>

        <Button
            android:id="@+id/btn_done"
            android:layout_width="120dp"
            android:layout_height="56dp"
            android:fontFamily="@font/font_extrabold"
            android:backgroundTint="#2962FF"
            android:text="@string/data_done"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="10dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>