<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="36dp">

    <TextView
        android:id="@+id/marker_text"
        android:layout_width="wrap_content"
        android:layout_height="23dp"
        android:background="@drawable/bg_marker"
        android:fontFamily="@font/font_extrabold"
        android:gravity="center"
        android:maxLines="1"
        android:paddingHorizontal="5dp"
        android:textColor="@color/white"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/marker_indicator"
        android:layout_width="7dp"
        android:layout_height="3dp"
        android:background="@drawable/marker_indicator"
        app:layout_constraintEnd_toEndOf="@id/marker_text"
        app:layout_constraintStart_toStartOf="@id/marker_text"
        app:layout_constraintTop_toBottomOf="@id/marker_text" />

    <View
        android:id="@+id/marker_circle"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/circle_marker_bg"

        app:layout_constraintEnd_toEndOf="@id/marker_text"
        app:layout_constraintStart_toStartOf="@id/marker_text"
        app:layout_constraintTop_toBottomOf="@id/marker_indicator" />

</androidx.constraintlayout.widget.ConstraintLayout>