<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue"
    tools:context=".ui.SplashActivity">

    <ImageView
        android:id="@+id/splash_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:src="@drawable/splash2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/splash_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha="0.3"
        android:pivotX="50%"
        android:pivotY="10%"
        android:src="@drawable/splash3"
        app:layout_constraintBottom_toBottomOf="@id/splash_4"
        app:layout_constraintEnd_toEndOf="@id/splash_4"
        app:layout_constraintStart_toStartOf="@id/splash_4"
        app:layout_constraintTop_toTopOf="@id/splash_4" />

    <ImageView
        android:id="@+id/splash_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginBottom="200dp"
        android:alpha="0.3"
        android:src="@drawable/splash4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/splash_4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:alpha="0.3"
        android:src="@drawable/splash6"
        app:layout_constraintBottom_toTopOf="@id/splash_3"
        app:layout_constraintStart_toStartOf="@id/splash_3" />

</androidx.constraintlayout.widget.ConstraintLayout>