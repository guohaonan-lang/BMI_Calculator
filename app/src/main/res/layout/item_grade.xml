<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="30dp"
    android:background="@drawable/grade_list_bg">

    <View
        android:id="@+id/item_grade_color"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginStart="19dp"
        android:background="@drawable/circle_bg"
        android:backgroundTint="@color/grad1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/item_grade_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:alpha="0.7"
        android:fontFamily="@font/font_regular"
        android:text="@string/adults_bmi_very_severely_underweight"
        android:textColor="@color/black"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/item_grade_color"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/item_grade_scope"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:alpha="0.7"
        android:fontFamily="@font/font_regular"
        android:text="@string/adults_bmi_range_VerySeverelyUnderweight"
        android:textColor="@color/black"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>